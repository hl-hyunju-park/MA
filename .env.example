# Copy to .env and fill in. .env is gitignored — never commit real secrets.
# Loaded by apps/agent/dart_agent.py (client) and mcps/dart-mcp/dart.py (server).

# Bearer token gating the DART MCP SSE server. Required by both the server (to gate
# access) and the client agent (to authenticate). Generate a fresh random value.
DART_MCP_TOKEN=

# OpenDART API key — required by the DART MCP server (mcps/dart-mcp/dart.py).
DART_API_KEY=
