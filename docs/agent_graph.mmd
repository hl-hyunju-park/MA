---
config:
  flowchart:
    curve: linear
---
graph TD;
	__start__([<p>__start__</p>]):::first
	agent(agent)
	lookup(lookup)
	open(open)
	finalize(finalize)
	__end__([<p>__end__</p>]):::last
	__start__ --> agent;
	agent -. &nbsp;answer&nbsp; .-> __end__;
	agent -.-> finalize;
	agent -.-> lookup;
	agent -.-> open;
	lookup --> agent;
	open --> agent;
	finalize --> __end__;
	agent -. &nbsp;continue&nbsp; .-> agent;
	classDef default fill:#f2f0ff,line-height:1.2
	classDef first fill-opacity:0
	classDef last fill:#bfb6fc
